    <!-- 通用功能 -->
    <string name="skip_splash_ad_title">跳过开屏广告</string>
    <string name="skip_splash_ad_summary">移除启动时的开屏广告，加快进入速度。</string>
    <string name="unlock_video_features_title">解锁视频功能</string>
    <string name="unlock_video_features_summary">尝试解锁部分试看限制与会员画质相关能力。</string>
    <string name="auto_like_video_detail_title">视频详情页自动点赞</string>
    <string name="auto_like_video_detail_summary">进入视频详情页时自动点击点赞按钮。</string>
    <string name="fix_live_quality_url_title">直播画质 URL 修复</string>
    <string name="fix_live_quality_url_summary">修复部分版本直播画质切换异常或 URL 错误的问题。</string>
    <string name="skip_mini_game_reward_ad_title">跳过小游戏激励广告</string>
    <string name="skip_mini_game_reward_ad_summary">自动快进或关闭小游戏中的激励视频广告。</string>
    <string name="custom_download_thread_title">自定义下载线程</string>
    <string name="custom_download_thread_summary">开启后在下载设置里显示“自定义下载线程”，与原有线程数选项分开。</string>
    <string name="custom_download_concurrency_title">自定义同时缓存数</string>
    <string name="custom_download_concurrency_summary">当前值：%1$d。点击调整自定义模式下的同时缓存数。</string>
    <string name="custom_download_concurrency_dialog_title">自定义同时缓存数</string>
    <string name="custom_download_thread_label">自定义</string>
    <string name="block_live_reservation_title">屏蔽直播预约</string>
    <string name="block_live_reservation_summary">移除视频详情页中的直播预约悬浮卡片。</string>
    <string name="block_live_room_qoe_popup_title">屏蔽直播间效果弹窗</string>
    <string name="block_live_room_qoe_popup_summary">移除直播间里的效果打分或体验调研弹窗。</string>
    <string name="disable_long_press_copy_title">去除长按复制</string>
    <string name="disable_long_press_copy_summary">禁用评论、动态、视频简介等场景里长按后直接复制到剪贴板的行为，减少误触。</string>
    <string name="enhance_long_press_copy_title">长按自由复制</string>
    <string name="enhance_long_press_copy_summary">需先开启“去除长按复制”。覆盖评论、动态、视频简介和部分私信场景，弹出可自由选择的文本窗口。</string>
    <string name="purify_share_title">分享净化</string>
    <string name="purify_share_summary">净化复制链接和分享文本中的追踪参数，尽量保留分页、评论定位等必要信息。</string>
    <string name="full_number_format_title">完整数字显示</string>
    <string name="full_number_format_summary">在“我的”和空间页显示完整统计数字，不再缩写为“万”“亿”。</string>
    <string name="unlock_comment_gif_title">评论区 GIF 解锁</string>
    <string name="unlock_comment_gif_summary">恢复评论区 GIF 缩略图播放，并移除图片右上角的大会员专属角标。</string>

