    <!-- 啟動與首頁 -->
    <string name="startup_skip_splash_title">跳过开屏广告</string>
    <string name="startup_skip_splash_summary">清理启动时的开屏广告响应，减少进入目标应用时的等待。</string>
    <string name="startup_block_teenagers_title">关闭青少年模式弹窗</string>
    <string name="startup_block_teenagers_summary">检测到青少年模式提醒弹窗时自动关闭（finish 掉该 Activity）。</string>
    <string name="home_recommend_ad_title">移除首页推荐广告</string>
    <string name="home_recommend_ad_summary">过滤首页推荐流中的大横幅、信息流广告和广告推广视频。</string>
    <string name="home_recommend_picture_title">移除首页推荐图文</string>
    <string name="home_recommend_picture_summary">过滤首页推荐流中的图文动态卡片。</string>
